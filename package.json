{
  "name": "antd-table-enhanced",
  "version": "0.1.5",
  "description": "A drop-in enhanced Ant Design Table with resizable, reorderable, and persistent columns.",
  "license": "MIT",
  "author": "Abhijeet Prasad <abhijeetoxide@gmail.com>",
  "type": "module",
  "main": "./dist/antd-table-enhanced.cjs",
  "module": "./dist/antd-table-enhanced.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/style.css",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/antd-table-enhanced.js",
      "require": "./dist/antd-table-enhanced.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "sideEffects": [
    "**/*.css",
    "**/*.less"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm typecheck && pnpm build",
    "demo:dev": "pnpm --filter antd-table-enhanced-demo dev",
    "demo:build": "pnpm --filter antd-table-enhanced-demo build",
    "demo:build:pages": "pnpm --filter antd-table-enhanced-demo build:pages",
    "demo:preview": "pnpm --filter antd-table-enhanced-demo preview"
  },
  "peerDependencies": {
    "@ant-design/icons": "^5.0.0",
    "antd": "^5.0.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@ant-design/icons": "^5.0.0",
    "@types/node": "^26.0.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "^4.0.0",
    "antd": "^5.0.0",
    "less": "^4.2.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vite-plugin-lib-inject-css": "^2.0.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "18.3.12",
      "@types/react-dom": "18.3.1",
      "react": "18.3.1",
      "react-dom": "18.3.1"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abhijeet-oxide/antd-table-enhanced.git"
  },
  "bugs": {
    "url": "https://github.com/abhijeet-oxide/antd-table-enhanced/issues"
  },
  "homepage": "https://github.com/abhijeet-oxide/antd-table-enhanced#readme",
  "keywords": [
    "antd",
    "ant-design",
    "react",
    "typescript",
    "table",
    "datatable",
    "resizable-columns",
    "reorderable-columns",
    "persistent-columns",
    "antd-table"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  }
}
